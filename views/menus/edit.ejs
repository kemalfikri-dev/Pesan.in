<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Menu</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
</head>
<body class="bg-light">
  <%- include('../partials/navbar') %>

  <div class="container mt-5 pt-3">
    <div class="row justify-content-center">
      <div class="col-md-6 col-lg-5">
        <div class="card card-hover shadow-lg">
          <div class="card-body p-5">
            <div class="text-center mb-4">
              <div class="bg-warning bg-opacity-10 text-warning rounded-circle d-inline-flex p-3 mb-3">
                <i class="bi bi-pencil-square fs-2"></i>
              </div>
              <h4 class="card-title fw-bold">Edit Menu</h4>
            </div>

            <% if (typeof error !== 'undefined' && error) { %>
              <div class="alert alert-danger"><%= error %></div>
            <% } %>

            <form action="/menus/edit/<%= menu.menus_id %>" method="POST">
              <div class="mb-3">
                <label class="form-label fw-semibold text-muted small">Nama Menu</label>
                <input type="text" name="menu_name" class="form-control form-control-lg bg-light" value="<%= menu.menu_name %>" required>
              </div>
              
              <div class="row mb-3">
                <div class="col-md-6">
                  <label class="form-label fw-semibold text-muted small">Harga (Rp)</label>
                  <input type="number" min="0" step="1000" name="price" class="form-control form-control-lg bg-light" value="<%= menu.price %>" required>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-semibold text-muted small">Kategori</label>
                  <select name="categories_id" class="form-select form-select-lg bg-light">
                    <% categories.forEach(category => { %>
                      <option value="<%= category.categories_id %>" <%= category.categories_id === menu.categories_id ? 'selected' : '' %>>
                        <%= category.categories_name %>
                      </option>
                    <% }) %>
                  </select>
                </div>
              </div>

              <div class="mb-4">
                <label class="form-label fw-semibold text-muted small">Deskripsi</label>
                <textarea name="description" class="form-control bg-light" rows="3" required><%= menu.description %></textarea>
              </div>

              <div class="d-flex gap-2 mt-4">
                <a class="btn btn-light text-muted w-50" href="/menus">Batal</a>
                <button type="submit" class="btn btn-warning w-50 text-dark fw-bold"><i class="bi bi-check-circle me-1"></i> Update Menu</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>