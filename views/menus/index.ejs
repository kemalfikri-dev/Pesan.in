<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Menus</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container mt-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-4">
      <h3 class="fw-bold mb-3 mb-md-0"><i class="bi bi-journal-text text-primary"></i> Daftar Menu</h3>
      
      <div class="d-flex gap-2">
        <% if (user && user.role === 'admin') { %>
          <a href="/menus/create" class="btn btn-primary shadow-sm"><i class="bi bi-plus-lg"></i> Tambah Menu</a>
          <!-- Tombol Trigger Modal Trash -->
          <button type="button" class="btn btn-outline-danger shadow-sm" data-bs-toggle="modal" data-bs-target="#trashModal">
            <i class="bi bi-trash3"></i> Arsip Sampah
          </button>
        <% } %>
      </div>
    </div>

    <!-- Search -->
    <div class="row mb-4">
      <div class="col-md-6">
        <form action="/menus" method="GET">
          <div class="input-group shadow-sm rounded-3 overflow-hidden">
            <span class="input-group-text bg-white border-0"><i class="bi bi-search text-muted"></i></span>
            <input type="text" name="search" class="form-control border-0" placeholder="Cari menu lezat..." value="<%= search %>">
            <button class="btn btn-primary px-4">Cari</button>
          </div>
        </form>
      </div>
    </div>

    <div class="table-container p-0">
      <table class="table table-hover mb-0">
        <thead>
          <tr>
            <th class="ps-4">No</th>
            <th>Nama Menu</th>
            <th>Kategori</th>
            <th>Harga</th>
            <th>Deskripsi</th>
            <% if (user && user.role === 'admin') { %>
            <th class="text-center">Aksi</th>
            <% } %>
          </tr>
        </thead>
        <tbody>
          <% menus.forEach((menu, index) => { %>
          <tr>
            <td class="ps-4 text-muted"><%= index + 1 %></td>
            <td class="fw-semibold"><%= menu.menu_name %></td>
            <td><span class="badge bg-secondary bg-opacity-25 text-secondary px-2 py-1 rounded-pill"><%= menu.categories_name %></span></td>
            <td class="text-success fw-bold">Rp <%= Number(menu.price).toLocaleString('id-ID') %></td>
            <td class="text-muted"><%= menu.description %></td>
            <% if (user && user.role === 'admin') { %>
            <td class="text-center">
              <div class="d-flex justify-content-center gap-2">
                <a href="/menus/edit/<%= menu.menus_id %>" class="btn btn-warning btn-sm text-dark"><i class="bi bi-pencil-square"></i> Edit</a>
                <!-- Soft delete (Arsip) -->
                <form action="/menus/soft-delete/<%= menu.menus_id %>" method="POST" class="m-0">
                  <button class="btn btn-secondary btn-sm"><i class="bi bi-archive"></i> Arsip</button>
                </form>
              </div>
            </td>
            <% } %>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% if (menus.length === 0) { %>
        <div class="text-center py-5 text-muted">Belum ada menu yang tersedia.</div>
      <% } %>
    </div>
  </div>

  <!-- MODAL TRASH / HARD DELETE -->
  <% if (user && user.role === 'admin') { %>
  <div class="modal fade" id="trashModal" tabindex="-1" aria-labelledby="trashModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content border-0 shadow-lg rounded-4">
        <div class="modal-header bg-danger text-white rounded-top-4 border-0">
          <h5 class="modal-title" id="trashModalLabel"><i class="bi bi-trash3 me-2"></i> Keranjang Sampah (Arsip)</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body p-0">
          <table class="table table-hover mb-0">
            <thead class="bg-light">
              <tr>
                <th class="ps-4">Nama Menu</th>
                <th>Kategori</th>
                <th class="text-center">Aksi Permanen</th>
              </tr>
            </thead>
            <tbody>
           
              <% if (typeof archivemenus !== 'undefined' && archivemenus.length > 0) { %>
                <% archivemenus.forEach((menu) => { %>
                <tr>
                  <td class="ps-4"><%= menu.menu_name %></td>
                  <td><%= menu.categories_name %></td>
                  <td class="text-center">
                    <div class="d-flex justify-content-center gap-2">
                        <form action="/menus/undo-delete/<%= menu.menus_id %>" method="POST" class="m-0">
                          <button class="btn btn-success btn-sm shadow-sm">
                            <i class="bi bi-arrow-counterclockwise me-1"></i> Pulihkan
                          </button>
                        </form>
                        <form action="/menus/hard-delete/<%= menu.menus_id %>" method="POST" class="m-0">
                          <button class="btn btn-danger btn-sm shadow-sm" onclick="return confirm('Hapus permanen menu ini? Tindakan tidak bisa dibatalkan.')">
                            <i class="bi bi-x-octagon me-1"></i> Hapus Permanen
                          </button>
                        </form>
                      </div>
                  </td>
                </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="3" class="text-center py-4 text-muted">Tidak ada menu yang diarsipkan.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
        <div class="modal-footer border-0">
          <button type="button" class="btn btn-light" data-bs-dismiss="modal">Tutup</button>
        </div>
      </div>
    </div>
  </div>
  <% } %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>