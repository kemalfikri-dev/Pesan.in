<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Categories</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h3 class="fw-bold"><i class="bi bi-tags text-warning"></i> Kategori Menu</h3>
      <a href="/categories/create" class="btn btn-warning shadow-sm"><i class="bi bi-plus-lg"></i> Tambah Kategori</a>
    </div>

    <div class="table-container p-0 col-md-8 mx-auto">
      <table class="table table-hover mb-0">
        <thead>
          <tr>
            <th class="ps-4" width="10%">No</th>
            <th>Nama Kategori</th>
            <th class="text-center" width="25%">Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% categories.forEach((category, index) => { %>
          <tr>
            <td class="ps-4 text-muted"><%= index + 1 %></td>
            <td class="fw-semibold"><%= category.categories_name %></td>
            
            <td class="text-center">
              <div class="d-flex justify-content-center gap-2">
                <a href="/categories/edit/<%= category.categories_id %>" class="btn btn-light border btn-sm text-dark"><i class="bi bi-pencil"></i></a>
                <form action="/categories/delete/<%= category.categories_id %>" method="POST" class="m-0">
                  <button type="submit" class="btn btn-danger btn-sm"><i class="bi bi-trash"></i></button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>